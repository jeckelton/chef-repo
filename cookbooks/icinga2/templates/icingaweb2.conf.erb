<VirtualHost *:80>
    ServerName <%= @server_name %>

    Alias /icingaweb2 /usr/share/icingaweb2/public

    <Directory /usr/share/icingaweb2/public>
        Options +FollowSymLinks
        AllowOverride None
        Require all granted
    </Directory>

    <FilesMatch \.php$>
        SetHandler "proxy:unix:/run/php/php-fpm.sock|fcgi://localhost"
    </FilesMatch>
</VirtualHost>
#This file is controlled by Chef, changing it here will leave you disappointed

grails.serverURL=<%= @server_url %>
dataSource.url = jdbc:mysql://localhost:3306/<%= @db_name %>?autoReconnect=true&useSSL=false
dataSource.username = <%= @db_user %>
dataSource.password = <%= @db_pass %>
dataSource.driverClassName = <%= @db_driver %>

rundeck.gui.staticUserResources.enabled = <%= @staticresource %>
rundeck.gui.logo = <%= @gui_logo %>
rundeck.gui.login.welcome= <%= @login_welcome %>
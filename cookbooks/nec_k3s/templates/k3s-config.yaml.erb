token: "<%= node['k3s']['token'] %>"

<% if @role == 'server' -%>
<% if @is_primary -%>
cluster-init: true
<% else -%>
server: "https://<%= node['k3s']['primary_server_ip'] %>:<%= node['k3s']['api_port'] %>"
<% end -%>

node-ip: "<%= node['k3s']['servers'][node['hostname']] %>"
advertise-address: "<%= node['k3s']['servers'][node['hostname']] %>"
write-kubeconfig-mode: "<%= node['k3s']['write_kubeconfig_mode'] %>"

tls-san:
<% node['k3s']['tls_sans'].uniq.each do |san| -%>
  - "<%= san %>"
<% end -%>

<% else -%>
server: "https://<%= node['k3s']['primary_server_ip'] %>:<%= node['k3s']['api_port'] %>"
node-ip: "<%= node['k3s']['agents'][node['hostname']] %>"
<% end -%>

node-name: "<%= node['hostname'] %>"
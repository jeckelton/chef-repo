version: '3.7'
services:
  unifi-controller:
    image: <%= @image %>
    container_name: <%= @container_name %>
    restart: <%= @restart %>
    environment:
      - PUID=<%= @PUID %>
      - PGID=<%= @PGID %>
      - TZ=<%= @TZ %>
    volumes:
      - /opt/unifi/config:/unifi:z
    ports:
      - "3478:3478/udp"
      - "10001:10001/udp"
      - "8080:8080"
      - "8443:8443"
      - "1900:1900/udp"
      - "8843:8843"
      - "8880:8880"
      - "6789:6789"
    privileged: <%= @privileged %>